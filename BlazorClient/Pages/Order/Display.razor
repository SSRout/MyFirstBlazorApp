@page "/Order/Display/{Id:int}"
@using System.Threading
@inject HttpClient Http
@inject NavigationManager navMgr

<h3>Display</h3>

@if (string.IsNullOrWhiteSpace(errorString) == false)
{
    <h4>System Error</h4>
    <p>@errorString</p>
}
else if (IsLoading)
{
    <p><em>Loading...</em></p>
}
else if (orderInfo?.Order is null)
{
    <h4>Order not found</h4>
}
else
{
    <table class="table">
        <tbody>
            <tr>
                <td><strong>Order Name</strong></td>
                <td>@orderInfo.Order.OrderName</td>
            </tr>
            <tr>
                <td><strong>Order Date</strong></td>
                <td>@orderInfo.Order.OrderDate</td>
            </tr>
            <tr>
                <td><strong>Order Total</strong></td>
                <td>@string.Format("{0:C}", orderInfo.Order.Total)</td>
            </tr>
            <tr>
                <td><strong>Quantity</strong></td>
                <td>@orderInfo.Order.Quantity</td>
            </tr>
            <tr>
                <td colspan="2">
                    @if (ConfirmDelete)
                    {
                        <button class="btn btn-outline-danger" @onclick="Delete" disabled="@IsDeleting">
                            @(IsDeleting ? "Deleting..." : "Confirm Delete Order")
                        </button>
                        <button class="btn btn-secondary" @onclick="(()=>ConfirmDelete=false)" disabled="@IsDeleting">Cancel Delete Order</button>
                    }
                    else
                    {
                        <button class="btn btn-danger" @onclick="(()=>ConfirmDelete=true)" disabled="@IsDeleting">Delete Order</button>
                    }
                </td>
            </tr>
        </tbody>
    </table>

    <EditForm Model="@upModel" OnValidSubmit="Update">
        <DataAnnotationsValidator />
        <ValidationSummary Model="@upModel" />
        <div class="form-group">
            <label class="control-label">Order Name</label>
            <InputText @bind-Value="upModel.OrderName" class="form-control" />
            <ValidationMessage For="@(()=>upModel.OrderName)" class="text-danger" />
        </div>
        <div class="form-group">
            <input type="submit" class="btn btn-outline-info" value="Update Order" disabled="@IsUpdating" />
            @if (IsUpdating)
            {
                <span class="ml-2">Updating...</span>
            }
        </div>
    </EditForm>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private OrderResultModel orderInfo = new OrderResultModel();
    private OrderUpdateModel upModel = new OrderUpdateModel();
    private string errorString;
    private bool ConfirmDelete = false;

    private bool IsLoading = true;
    private bool IsUpdating = false;
    private bool IsDeleting = false;

    private CancellationTokenSource _cts = new CancellationTokenSource();

    protected override async Task OnParametersSetAsync()
    {
        // Cancel any prior in-flight requests, create a fresh token for this load
        _cts.Cancel();
        _cts.Dispose();
        _cts = new CancellationTokenSource();

        await LoadOrderAsync(_cts.Token);
    }

    private async Task LoadOrderAsync(CancellationToken ct)
    {
        IsLoading = true;
        errorString = null;

        try
        {
            using var response = await Http.GetAsync($"Order/{Id}", ct);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<OrderResultModel>(cancellationToken: ct);
                if (result?.Order != null)
                {
                    orderInfo = result;
                    upModel.Id = orderInfo.Order.Id;
                    upModel.OrderName = orderInfo.Order.OrderName;
                }
                else
                {
                    orderInfo = new OrderResultModel();
                    errorString = "Order not found.";
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                orderInfo = new OrderResultModel();
                errorString = "Order not found (404).";
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                errorString = !string.IsNullOrWhiteSpace(content) ? content : response.ReasonPhrase;
            }
        }
        catch (OperationCanceledException)
        {
            // ignore cancellation
        }
        catch (Exception ex)
        {
            errorString = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task Update()
    {
        if (IsUpdating) return;

        IsUpdating = true;
        errorString = null;

        try
        {
            using var response = await Http.PutAsJsonAsync("Order", upModel);
            if (response.IsSuccessStatusCode)
            {
                // Optimistically update UI
                if (orderInfo?.Order != null)
                {
                    orderInfo.Order.OrderName = upModel.OrderName;
                }
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                errorString = !string.IsNullOrWhiteSpace(content) ? content : response.ReasonPhrase;
            }
        }
        catch (Exception ex)
        {
            errorString = ex.Message;
        }
        finally
        {
            IsUpdating = false;
        }
    }

    private async Task Delete()
    {
        if (IsDeleting) return;

        IsDeleting = true;
        errorString = null;

        try
        {
            using var response = await Http.DeleteAsync($"Order/{Id}");
            if (response.IsSuccessStatusCode)
            {
                navMgr.NavigateTo($"Order/Create");
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                errorString = !string.IsNullOrWhiteSpace(content) ? content : response.ReasonPhrase;
            }
        }
        catch (Exception ex)
        {
            errorString = ex.Message;
        }
        finally
        {
            IsDeleting = false;
            ConfirmDelete = false;
        }
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = null;
    }
}
